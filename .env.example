# ── Octagonl SSO (required) ──────────────────────────────────
# Get these from the Platform Team after requesting an app registration.
# See: docs/octagonl-platform-infra/docs/app-integration/README.md
OIDC_ISSUER=https://login.octago.nl/<tenant-id>/v2.0
OIDC_CLIENT_ID=<your-app-registration-client-id>
OIDC_CLIENT_SECRET=<from-azure-key-vault>

# ── NextAuth (required) ─────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=<generate-with-openssl-rand-base64-32>

# ── Platform API ─────────────────────────────────────────────
NEXT_PUBLIC_PLATFORM_API_BASE_URL=https://api.octago.nl
PLATFORM_API_BASE_URL=https://api.octago.nl

# ── Azure (set by infra, not typically needed locally) ───────
# KEY_VAULT_URI=https://kv-octagonl-appname-dev.vault.azure.net/
# APPLICATIONINSIGHTS_CONNECTION_STRING=<from-azure>
